{
  "name": "aibaby",
  "private": true,
  "version": "0.0.0",
  "description": "Initial monorepo scaffold for the AI Baby MVP",
  "scripts": {
    "dev:web": "npm run dev --workspace @aibaby/web",
    "dev:mobile": "npm run dev --workspace @aibaby/mobile",
    "commander:sync": "node scripts/commander-sync.mjs",
    "test:commander-sync": "node --test scripts/commander-sync.test.mjs",
    "test:team-log-check": "node --test scripts/check-team-log-update.test.mjs",
    "test": "npm run test:commander-sync && npm run test:team-log-check && npm test --workspaces --if-present"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "5.6.2",
    "react-native-web": "0.21.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
