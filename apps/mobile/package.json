{
  "name": "@aibaby/mobile",
  "private": true,
  "version": "0.0.0",
  "description": "Expo / React Native app scaffold placeholder for AI Baby",
  "main": "expo-router/entry",
  "type": "module",
  "scripts": {
    "start": "expo start",
    "test:app-shell": "node --experimental-strip-types --test src/features/app-shell/*.test.ts",
    "test:baby-profile-flow": "node --experimental-strip-types --test src/features/baby-profile/*.test.ts",
    "test:chat-input": "node --experimental-strip-types --test src/features/chat-input/*.test.ts",
    "test:reminders": "node --experimental-strip-types --test src/features/reminders/*.test.ts",
    "test:review": "node --experimental-strip-types --test src/features/review/*.test.ts",
    "test:summary-history": "node --experimental-strip-types --test src/features/summary-history/*.test.ts"
  },
  "dependencies": {
    "@aibaby/ui": "0.0.0",
    "@react-native-community/datetimepicker": "^8.4.4",
    "expo": "^54.0.0",
    "expo-image-picker": "^55.0.12",
    "expo-router": "^6.0.0",
    "react": "^19.1.0",
    "react-native": "^0.81.0",
    "react-native-safe-area-context": "^5.6.0"
  },
  "devDependencies": {
    "babel-preset-expo": "^54.0.7"
  }
}
